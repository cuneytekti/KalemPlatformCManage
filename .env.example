# ── Alan adı ve TLS ──────────────────────────────────────────────
BASE_DOMAIN=kalemplatform.com
ACME_EMAIL=admin@kalemplatform.com
ACME_DNS_PROVIDER=cloudflare
CF_DNS_API_TOKEN=

# ── Veritabanı ───────────────────────────────────────────────────
CMANAGE_DB_PASSWORD=degistir-beni
# Üretimde false: şema migration'larla yönetilir (açılışta otomatik çalışır).
# Geliştirmede true bırakılabilir (synchronize).
DB_SYNCHRONIZE=false

# ── Tenant imajları (registry'ye push edilmiş olmalı) ────────────
KALEM_API_IMAGE=ghcr.io/cuneytekti/kalem-api:latest
KALEM_WEB_IMAGE=ghcr.io/cuneytekti/kalem-backoffice-web:latest

# ── Web sitesi satış webhook imza anahtarı ───────────────────────
WEBHOOK_SECRET=degistir-beni

# ── Panel kimlik doğrulama ───────────────────────────────────────
# Üretim: openssl rand -base64 48
CMANAGE_JWT_SECRET=degistir-beni
CMANAGE_ADMIN_EMAIL=admin@kalemplatform.com
# İlk açılışta tohumlanan admin şifresi — ilk girişte panelden değiştirin
CMANAGE_ADMIN_PASSWORD=degistir-beni

# ── PashaBank ECOMM sanal POS ────────────────────────────────────
# Banka sözleşmesi sonrası verilen mTLS sertifikası ile çalışır.
# Boş bırakılırsa web sitesinden satın alma kapalıdır (demo formu çalışır).
PASHA_MERCHANT_HANDLER=https://ecomm.pashabank.az:18443/ecomm2/MerchantHandler
PASHA_CLIENT_HANDLER=https://ecomm.pashabank.az:8463/ecomm2/ClientHandler
# PEM sertifika/anahtar (p12'den: openssl pkcs12 -in merchant.p12 -out cert.pem ...)
PASHA_CERT_PATH=/run/secrets/pasha-cert.pem
PASHA_KEY_PATH=/run/secrets/pasha-key.pem
PASHA_KEY_PASSPHRASE=
# true: banka çağrıları taklit edilir (yalnız staging testleri için!)
PASHA_MOCK=false

# ── E-posta (SMTP) ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Kalem Platform <info@kalemyazilim.az>

# ── Fiyatlandırma varsayılanları (Lead→Teklif) ───────────────────
DEFAULT_PRICE_USER=15.00
DEFAULT_PRICE_POS=49.00
DEFAULT_PRICE_MOBILE=19.00

# ── Gecikmiş faturada otomatik askıya alma (gün; 0=kapalı) ───────
AUTO_SUSPEND_OVERDUE_DAYS=0
